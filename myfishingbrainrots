-- MUTATION + EGG NAME FINAL FIX (multi-mutation support)
-- =========================
local MutationPrefixes = {}
if ReplicatedStorage:FindFirstChild("Assets")
and ReplicatedStorage.Assets:FindFirstChild("VFX")
and ReplicatedStorage.Assets.VFX:FindFirstChild("MutationVFX") then
    for _, mut in ipairs(ReplicatedStorage.Assets.VFX.MutationVFX:GetChildren()) do
        local clean = mut.Name:gsub("MutationVFX_", "")
        table.insert(MutationPrefixes, clean)
    end
end

local function table_contains(t, val)
    for _, v in ipairs(t) do
        if v == val then return true end
    end
    return false
end
-- ensure "Fishing Master" included as special-case name-based mutation
if not table_contains(MutationPrefixes, "Fishing Master") then
    table.insert(MutationPrefixes, "Fishing Master")
end

-- Return an array (possibly empty) of mutation names found on the egg
local function GetEggMutations(egg)
    local results = {}
    if not egg then return results end

    local ename = tostring(egg.Name or "")

    -- 1) name-based prefix detection (e.g. "Gold Stinky Gorillo")
    -- NOTE: we check prefixes at the start but don't rely on this alone (we also detect MutationVFX)
    for _, prefix in ipairs(MutationPrefixes) do
        if ename:sub(1, #prefix + 1) == prefix .. " " then
            if not table_contains(results, prefix) then
                table.insert(results, prefix)
            end
        end
    end

    -- 2) MutationVFX descendants (detect multiple)
    for _, d in ipairs(egg:GetDescendants()) do
        if type(d.Name) == "string" and d.Name:match("^MutationVFX_") then
            local clean = d.Name:gsub("MutationVFX_", "")
            if not table_contains(results, clean) then
                table.insert(results, clean)
            end
        end
    end

    return results -- may be empty
end

-- IMPROVED: remove ALL mutation prefixes from start of eggName to obtain base name
local function GetBaseEggName(eggName)
    if not eggName or eggName == "" then return eggName end
    local name = tostring(eggName)
    local changed = true
    -- keep stripping while a prefix matches the beginning
    while changed do
        changed = false
        for _, prefix in ipairs(MutationPrefixes) do
            local pattern = prefix .. " "
            if name:sub(1, #pattern) == pattern then
                name = name:sub(#pattern + 1)
                changed = true
                break
            end
        end
    end
    -- trim leading/trailing spaces
    name = name:gsub("^%s+", ""):gsub("%s+$", "")
    return name
end

