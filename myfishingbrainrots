local Config = {}

local function saveConfigToFile()
    if not hasFileAPI() then
        -- fallback: session storage
        getgenv().NUAR_CONFIG = HttpService:JSONEncode(Config)
        return
    end
    pcall(function()
        writefile(CONFIG_FILE, HttpService:JSONEncode(Config))
    end)
end

local function loadConfigFromFile()
    -- start with defaults copy
    Config = {}
    for k,v in pairs(DefaultConfig) do Config[k] = v end

    if hasFileAPI() and isfile(CONFIG_FILE) then
        local ok, raw = pcall(readfile, CONFIG_FILE)
        if ok and raw then
            local suc, tbl = pcall(HttpService.JSONDecode, HttpService, raw)
            if suc and type(tbl) == "table" then
                for k,v in pairs(tbl) do Config[k] = v end
            end
        end
    else
        -- fallback: session
        if getgenv().NUAR_CONFIG then
            local suc, tbl = pcall(HttpService.JSONDecode, HttpService, getgenv().NUAR_CONFIG)
            if suc and type(tbl) == "table" then
                for k,v in pairs(tbl) do Config[k] = v end
            end
        end
    end

    -- defensive: ensure MutationToggles exists and is a table
    if type(Config.MutationToggles) ~= "table" then
        Config.MutationToggles = {}
    end
    if Config.EnableMutationFilter == nil then
        Config.EnableMutationFilter = DefaultConfig.EnableMutationFilter
    end
    if Config.FindWeatherEnabled == nil then Config.FindWeatherEnabled = DefaultConfig.FindWeatherEnabled end
    if Config.FindWeatherMaxWaitMinutes == nil then Config.FindWeatherMaxWaitMinutes = DefaultConfig.FindWeatherMaxWaitMinutes end
    if Config.FindWeatherMaxWaitMinutes2 == nil then Config.FindWeatherMaxWaitMinutes2 = DefaultConfig.FindWeatherMaxWaitMinutes2 end
    if Config.WeatherToggles == nil or type(Config.WeatherToggles) ~= "table" then Config.WeatherToggles = {} end
    if Config.EnableBuyMultipleMutation == nil then Config.EnableBuyMultipleMutation = DefaultConfig.EnableBuyMultipleMutation end
end

