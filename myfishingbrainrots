local function ReadEggUI(eggModel)
    local ok, frame = pcall(function()
        return eggModel["Meshes/Begg (8)"].BillboardAttachment.EggBillboard.Frame
    end)
    if not ok or not frame then
        local fallbackFrame = nil
        pcall(function()
            for _, d in ipairs(eggModel:GetDescendants()) do
                if d:IsA("Frame") and d:FindFirstChild("EggName") then
                    fallbackFrame = d
                    break
                end
            end
        end)
        frame = fallbackFrame
    end

    if not frame then
        return "Unknown", "Unknown", "Unknown"
    end

    local eggName = (frame:FindFirstChild("EggName") and frame.EggName:IsA("TextLabel") and frame.EggName.Text) or "Unknown"
    local price   = (frame:FindFirstChild("Price") and frame.Price:IsA("TextLabel") and frame.Price.Text) or "Unknown"
    local rarity  = (frame:FindFirstChild("Rarity") and frame.Rarity:IsA("TextLabel") and frame.Rarity.Text) or "Unknown"

    eggName = tostring(eggName)
    price = tostring(price)
    rarity = tostring(rarity)

    return eggName, price, rarity
end

local function SendEggWebhook(name, price, rarity, mutation)
    if not WebhookEnabled then
        DebugPrint("Webhook disabled, skipping send.")
        return
    end
    if not WebhookURL or WebhookURL == "" then
        DebugPrint("Webhook URL kosong, set dulu di UI.")
        return
    end

    local fields = {
        { name = "Player", value = tostring(LP.Name), inline = true },
        { name = "Egg", value = tostring(name), inline = true },
        { name = "Price", value = tostring(price), inline = true },
        { name = "Rarity", value = tostring(rarity), inline = true }
    }
    if mutation and tostring(mutation) ~= "nil" then
        table.insert(fields, { name = "Mutation", value = tostring(mutation), inline = true })
    end
    table.insert(fields, { name = "Server JobId", value = tostring(game.JobId), inline = false })

    if DiscordInviteLink and DiscordInviteLink ~= "" then
        table.insert(fields, { name = "Join Discord", value = tostring(DiscordInviteLink), inline = false })
    end

    local embed = {
        title = "🥚 Egg Bought!",
        description = "A new egg was successfully bought — details below.",
        color = 1752220,
        fields = fields,
        footer = { text = "Made By nibum HUB" },
        timestamp = DateTime.now():ToIsoDate()
    }

    if ProfileImageURL and ProfileImageURL ~= "" then
        embed.thumbnail = { url = ProfileImageURL }
        embed.footer.icon_url = ProfileImageURL
        embed.author = { name = WebhookDisplayName or "Egg Notifier", icon_url = ProfileImageURL }
    else
        embed.author = { name = WebhookDisplayName or "Egg Notifier" }
    end

    local payload = {
        username = WebhookDisplayName or "Egg Notifier",
        avatar_url = (ProfileImageURL and ProfileImageURL ~= "") and ProfileImageURL or nil,
        embeds = { embed }
    }

    if WebhookPingEnabled and WebhookPingID and WebhookPingID ~= "" then
        payload.content = "<@" .. tostring(WebhookPingID) .. ">"
    end

    local body = HttpService:JSONEncode(payload)

    local requestFunc =
        request or
        http_request or
        (syn and syn.request) or
        (http and http.request) or
        (fluxus and fluxus.request)

    if requestFunc then
        local success, res = pcall(function()
            return requestFunc({
                Url = WebhookURL,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body
            })
        end)

        if not success then
            DebugPrint("request() call failed:", res)
        else
            local statusCode = nil
            if type(res) == "table" then
                statusCode = res.StatusCode or res.status or res.Status or res.code
            end

            if statusCode == 200 or statusCode == 204 or statusCode == 201 or statusCode == nil then
                DebugPrint("Webhook sent (via request). status:", statusCode)
                return
            else
                DebugPrint("Webhook request returned status:", statusCode)
            end
        end
    end

    local ok, err = pcall(function()
        HttpService:PostAsync(WebhookURL, body, Enum.HttpContentType.ApplicationJson)
    end)
    if ok then
        DebugPrint("Webhook sent (via PostAsync).")
    else
        DebugPrint("Failed to send webhook (both request and PostAsync):", err)
    end
end

-- helper: returns true if any mutation in 'mutations' is enabled in MutationToggles
-- UPDATED: supports Config.EnableBuyMultipleMutation behavior
local function AnyMutationAllowed(mutations)
    if not mutations or #mutations == 0 then return false end

    -- if enabled, accept eggs that contain ANY selected mutation (even if egg has multiple mutations)
    if Config.EnableBuyMultipleMutation then
        for _, m in ipairs(mutations) do
            if Config.MutationToggles[m] then
                return true
            end
        end
        return false
    else
        -- if disabled, only accept eggs that have exactly one mutation and that mutation is selected
        if #mutations ~= 1 then
            return false
        end
        return Config.MutationToggles[mutations[1]] == true
    end
end

