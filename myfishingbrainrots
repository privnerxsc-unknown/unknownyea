-- Background watcher/hopper (updated to consider both mutation and world timers)
task.spawn(function()
    while true do
        task.wait(2)

        if not (Config.FindWeatherEnabled and hasSelectedWeather()) then
            task.wait(3)
            continue
        end

        -- If an event is active (we rely on RE event name), prefer staying until it finishes or not desired
        if CurrentWeatherName then
            if currentWeatherMatchesSelection() then
                -- desired weather active, stop hopping & notify
                Rayfield:Notify({Title="Weather Finder", Content="Desired weather found: "..tostring(CurrentWeatherName), Duration=4})
                -- wait longer while event is active to avoid immediate hops (gives time for buying logic)
                local waitSeconds = math.max(30, tonumber(CurrentWeatherTimerSeconds or 30))
                local waited = 0
                while waited < waitSeconds and Config.FindWeatherEnabled and currentWeatherMatchesSelection() do
                    task.wait(1)
                    waited = waited + 1
                end
                -- continue loop (re-evaluate)
            else
                -- weather active but not desired -> hop
                Rayfield:Notify({Title="Weather Finder", Content="Weather active but not desired ("..tostring(CurrentWeatherName).."). Hoping...", Duration=4})
                HopToRandomServer()
                task.wait(10)
            end
        else
            -- no active event; check both timer infos (mutation vs world)
            local mutationRemaining = MutationTimerSeconds
            local worldRemaining = WorldTimerSeconds

            local mutationMaxSec = (Config.FindWeatherMaxWaitMinutes or 0) * 60
            local worldMaxSec = (Config.FindWeatherMaxWaitMinutes2 or 0) * 60

            local shouldWaitForMutation = (mutationRemaining and mutationRemaining > 0 and mutationMaxSec > 0 and mutationRemaining <= mutationMaxSec)
            local shouldWaitForWorld = (worldRemaining and worldRemaining > 0 and worldMaxSec > 0 and worldRemaining <= worldMaxSec)

            if shouldWaitForMutation or shouldWaitForWorld then
                -- notify which timers triggered
                local info = {}
                if shouldWaitForMutation then table.insert(info, "mutation in "..tostring(math.floor(mutationRemaining)).."s") end
                if shouldWaitForWorld then table.insert(info, "world in "..tostring(math.floor(worldRemaining)).."s") end
                Rayfield:Notify({Title="Weather Finder", Content="Event spawning soon ("..table.concat(info, " & ").."). Waiting.", Duration=4})

                -- determine reasonable wait limit (so we don't wait forever)
                local waitLimit = math.max(30, (mutationRemaining or 0) + 10, (worldRemaining or 0) + 10)
                local waited = 0
                while not CurrentWeatherName and waited < waitLimit and Config.FindWeatherEnabled do
                    task.wait(1)
                    waited = waited + 1
                end
                -- re-evaluate loop
            else
                -- no event soon or no timer info -> hop
                Rayfield:Notify({Title="Weather Finder", Content="No weather soon, hopping server...", Duration=3})
                HopToRandomServer()
                task.wait(10)
            end
        end
    end
end)

