-- helper: parse timer "HH:MM:SS" or "MM:SS" or "SS" into seconds
local function parseTimerText(txt)
    if not txt or txt == "" then return nil end
    local parts = {}
    for part in string.gmatch(txt, "[^:]+") do
        table.insert(parts, tonumber(part) or 0)
    end
    if #parts == 1 then return parts[1] end
    if #parts == 2 then return parts[1]*60 + parts[2] end
    if #parts >= 3 then return parts[1]*3600 + parts[2]*60 + parts[3] end
    return nil
end

-- We will detect two distinct timers explicitly:
--  - Frame.Timer => mutation event timer
--  - Frame2.Timer => world event timer
local MutationTimerSeconds = nil
local WorldTimerSeconds = nil
local timerLabelRefs = {} -- { label = TextLabel, type = "mutation"|"world", conn = connection }

local function clearTimerLabelConnections()
    for _, entry in ipairs(timerLabelRefs) do
        if entry.conn then
            pcall(function() entry.conn:Disconnect() end)
        end
    end
    timerLabelRefs = {}
end

local function updateFromLabel(lbl, typ)
    pcall(function()
        local s = tostring(lbl.Text or "")
        local parsed = parseTimerText(s)
        if typ == "mutation" then
            if parsed then MutationTimerSeconds = parsed end
        elseif typ == "world" then
            if parsed then WorldTimerSeconds = parsed end
        end
    end)
end

local function discoverAndAttachSpecificTimers()
    clearTimerLabelConnections()

    local ok, surfaceGui = pcall(function()
        return Workspace
            :WaitForChild("CoreObjects", 2)
            :WaitForChild("WeatherEventCountdown", 2)
            :WaitForChild("Board", 2)
            :WaitForChild("SurfaceGui", 2)
    end)
    if not ok or not surfaceGui then
        return
    end

    -- Find Frame.Timer explicitly (mutation)
    pcall(function()
        local frame = surfaceGui:FindFirstChild("Frame")
        if frame then
            local t = frame:FindFirstChild("Timer")
            if t and t:IsA("TextLabel") then
                local entry = { label = t, type = "mutation", conn = nil }
                pcall(function() updateFromLabel(t, "mutation") end)
                entry.conn = t:GetPropertyChangedSignal("Text"):Connect(function()
                    pcall(function() updateFromLabel(t, "mutation") end)
                end)
                table.insert(timerLabelRefs, entry)
            end
        end
    end)

    -- Find Frame2.Timer explicitly (world)
    pcall(function()
        local frame2 = surfaceGui:FindFirstChild("Frame2")
        if frame2 then
            local t2 = frame2:FindFirstChild("Timer")
            if t2 and t2:IsA("TextLabel") then
                local entry2 = { label = t2, type = "world", conn = nil }
                pcall(function() updateFromLabel(t2, "world") end)
                entry2.conn = t2:GetPropertyChangedSignal("Text"):Connect(function()
                    pcall(function() updateFromLabel(t2, "world") end)
                end)
                table.insert(timerLabelRefs, entry2)
            end
        end
    end)

    -- Fallback: if explicit Frame/Frame2 not found, scan descendants and classify by ancestor names
    if #timerLabelRefs == 0 then
        for _, desc in ipairs(surfaceGui:GetDescendants()) do
            if desc and desc:IsA("TextLabel") and desc.Name == "Timer" then
                local up = desc.Parent
                local typ = nil
                pcall(function()
                    while up and up ~= surfaceGui do
                        if up.Name == "Frame2" then typ = "world" break end
                        if up.Name == "Frame" then typ = "mutation" break end
                        up = up.Parent
                    end
                end)
                if not typ then
                    -- if cannot classify, skip
                else
                    local entry = { label = desc, type = typ, conn = nil }
                    pcall(function() updateFromLabel(desc, typ) end)
                    entry.conn = desc:GetPropertyChangedSignal("Text"):Connect(function()
                        pcall(function() updateFromLabel(desc, typ) end)
                    end)
                    table.insert(timerLabelRefs, entry)
                end
            end
        end
    end
end

-- initial discovery + periodic rediscovery
discoverAndAttachSpecificTimers()
task.spawn(function()
    while true do
        -- if we've lost all references or they got removed, rediscover
        local need = false
        if #timerLabelRefs == 0 then
            need = true
        else
            local alive = false
            for _, e in ipairs(timerLabelRefs) do
                if e.label and e.label.Parent then alive = true break end
            end
            if not alive then need = true end
        end
        if need then
            discoverAndAttachSpecificTimers()
        end
        task.wait(3)
    end
end)

