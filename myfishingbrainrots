local FoodOrder = {"Ham","Fries","Hotdog","Pizza","Burger"}

local function FindFoodTool()
    -- search Character first (equipped), then Backpack
    if LP.Character then
        for _, name in ipairs(FoodOrder) do
            local tool = LP.Character:FindFirstChild(name)
            if tool and tool:IsA("Tool") then return tool end
        end
    end
    for _, name in ipairs(FoodOrder) do
        local tool = LP.Backpack:FindFirstChild(name)
        if tool and tool:IsA("Tool") then return tool end
    end
    return nil
end

local function FindBrainrotModel()
    -- look for any plot that has PlotExtensions.GiantBrainrot.BrainrotModel with children
    if not Workspace:FindFirstChild("CoreObjects") or not Workspace.CoreObjects:FindFirstChild("Plots") then return nil end
    for _, plot in pairs(Workspace.CoreObjects.Plots:GetChildren()) do
        local ext = plot:FindFirstChild("PlotExtensions")
        if ext then
            local giant = ext:FindFirstChild("GiantBrainrot")
            if giant then
                local model = giant:FindFirstChild("BrainrotModel")
                if model and #model:GetChildren() > 0 then
                    return model
                end
            end
        end
    end
    return nil
end

-- =========================
-- MAIN LOOP (with Auto Feed priority)
-- =========================
task.spawn(function()
    while task.wait(0.2) do
        local now = os.clock()

        -- PRIORITY: AUTO FEED BRAINROT (spam) ------------------------------------------------
        if AutoFeedBrainrot and FeedRemote then
            local brainModel = FindBrainrotModel()
            if brainModel then
                -- attempt to feed repeatedly while we have food and brainrot exists and toggle still true
                while AutoFeedBrainrot and brainModel.Parent and FindBrainrotModel() do
                    local tool = FindFoodTool()
                    if not tool then break end

                    -- equip tool if in backpack
                    pcall(function()
                        local humanoid = (LP.Character and LP.Character:FindFirstChildOfClass("Humanoid"))
                        if humanoid and tool.Parent == LP.Backpack then
                            humanoid:EquipTool(tool)
                        end
                    end)

                    -- call feed remote (safe)
                    pcall(function()
                        -- Some remotes use InvokeServer, some might use FireServer: we try Invoke then Fire
                        local suc, _ = pcall(function() FeedRemote:InvokeServer() end)
                        if not suc then
                            pcall(function() FeedRemote:FireServer() end)
                        end
                    end)

                    -- small delay to spam quickly but avoid locking too tight
                    task.wait(0.12)
                end

                -- after feeding attempt, continue main loop (skip collect/sell this iteration)
                continue
            end
        end

        -- AUTO COLLECT (only runs if feed didn't run / no brainrot to feed)
        if AutoCollect and now - LastCollect >= CollectDelay then
            LastCollect = now
            local re = ReplicatedStorage.Shared.Packages.Networker:FindFirstChild("RE/PickupBoxes")
            if re then
                re:FireServer()
            end
        end

        -- AUTO SELL
        if AutoSell and MyPlot and now - LastSell >= SellDelay then
            LastSell = now

            local boxes = GetBoxes()
            if #boxes == 0 then continue end

            local char = LP.Character or LP.CharacterAdded:Wait()
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:WaitForChild("HumanoidRootPart")

            local rig = MyPlot:FindFirstChild("Rig", true)
