                    hrp.CFrame = rigHRP.CFrame + Vector3.new(0,3,0)
                end

                for _, box in ipairs(boxes) do
                    if box and box.Parent then
                        humanoid:EquipTool(box)
                        task.wait(0.1)
                        fireproximityprompt(prompt)
                        task.wait(0.15)
