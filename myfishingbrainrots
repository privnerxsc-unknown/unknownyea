-- helpers to check selection (UPDATED to use WeatherToggles)
local function hasSelectedWeather()
    for k,v in pairs(Config.WeatherToggles or {}) do
        if v then return true end
    end
    return false
end

-- more robust weather matching: check substring both ways, case-insensitive
local function currentWeatherMatchesSelection()
    if not CurrentWeatherName then return false end
    local cw = tostring(CurrentWeatherName):lower()
    for name, enabled in pairs(Config.WeatherToggles or {}) do
        if enabled then
            local n = tostring(name):lower()
            if n ~= "" then
                if cw:find(n, 1, true) or n:find(cw, 1, true) then
                    return true
                end
            end
        end
    end
    return false
end

-- get random server job id via Roblox public API (requires request/http)
local function getRandomServerJobId()
    local placeId = tostring(game.PlaceId)
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
    local requestFunc =
        request or
        http_request or
        (syn and syn.request) or
        (http and http.request) or
        (fluxus and fluxus.request)

    if not requestFunc then
        warn("[WeatherFinder] No HTTP request function available.")
        return nil
    end

    local ok, res = pcall(function()
        return requestFunc({Url = url, Method = "GET"})
    end)
    if not ok or not res then return nil end
    local body = res.Body or res.body
    if not body then return nil end

    local suc, parsed = pcall(function() return HttpService:JSONDecode(body) end)
    if not suc or type(parsed) ~= "table" or not parsed.data then return nil end

    local potential = {}
    for _, server in ipairs(parsed.data) do
        local jid = server.id
        if jid and tostring(jid) ~= tostring(game.JobId) then
            table.insert(potential, server)
        end
    end

    if #potential == 0 then return nil end
    local pick = potential[math.random(1, #potential)]
    return pick.id
end

local function HopToRandomServer()
    local jobId = getRandomServerJobId()
    if not jobId then
        Rayfield:Notify({Title="Weather Finder", Content="No server found to hop.", Duration=4})
        return false
    end
    Rayfield:Notify({Title="Weather Finder", Content="Teleporting in 16s...", Duration=4})
    task.wait(16)
    pcall(function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LP)
    end)
    return true
end

